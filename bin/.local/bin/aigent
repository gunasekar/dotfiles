#!/usr/bin/env sh
# fzf agent picker. Used as `aigent` from any shell, as nvim's right-panel agent
# terminal command (lua/plugins/agents.lua), and as Zed's agent.terminal_init_command.
#
#   aigent                  pick a running session to rejoin, or an agent to start
#   aigent new              skip the running sessions, start a fresh one
#   aigent status           every agent session on the box, TSV, for a notifier to read
#   aigent commit [ctx...]  stage + commit via the /commit skill, no session
#
# Env:
#   AGENT_SETTLE           seconds between the two screen samples (default 0.35)
#   AGENT_ASK_RE           regex meaning "the agent is asking you something"
#
# `aigent`, not `agent`: ~/.local/bin is a shared namespace, and cursor-agent ships
# a binary called `agent` that overwrote this script's symlink on install and on
# every self-update. Owning a name a vendor also wants is a fight you re-lose on
# every update, so don't share it.
#
# Sessions live in tmux, one per agent, named aigent-<project>. $PREFIX below is the
# only definition of "a session of ours", so changing it orphans anything already
# running — rename live sessions rather than strand them:
#   tmux rename-session -t agent-foo aigent-foo
#
# Why tmux: Zed's remote mode runs this on the ssh host, and when Zed disconnects the
# agent process dies with its terminal, leaving `claude --resume` (which replays the
# transcript into a *new* process) as the only way back. Held in tmux the process
# stays alive, so reconnecting re-attaches to the running conversation with nothing to
# resume. Every frontend goes through this one script; the same session is reachable
# from a plain terminal with `tmux a -t aigent-<project>`.

# ─── Agent registry ──────────────────────────────────────────────────────────
# name|command|args — the single source of truth. Drives the menu, the PATH filter
# and the launch, so adding an agent is one line here and nothing else.
AGENTS='claude|claude|
cursor|cursor-agent|
antigravity|agy|
opencode|opencode|
pi|pi|
claude/plan|claude|--agent Plan --model opus
claude/explore|claude|--agent Explore --model sonnet
claude/yolo|claude|--dangerously-skip-permissions'

agent_row() {
  printf '%s\n' "$AGENTS" | awk -F'|' -v n="$1" '$1 == n { print; exit }'
}

# Only offer an agent whose command actually exists here.
available_agents() {
  printf '%s\n' "$AGENTS" | while IFS='|' read -r name cmd _; do
    command -v "$cmd" >/dev/null 2>&1 && printf '%s\n' "$name"
  done
}

# ─── This project's sessions ─────────────────────────────────────────────────
# The one place the session prefix is spelled. sessions() and is_ours() both read it
# from here rather than hard-coding the string — two copies is two chances to rename
# only one of them.
PREFIX=aigent-

# tmux forbids '.' and ':' in session names (both are target separators), and spaces
# make `tmux a -t <name>` a quoting chore. Two projects sharing a basename both want
# this name; the loser lands on an -N sibling and is_ours tells them apart by path.
SESSION=$PREFIX$(basename "$PWD" | tr ':. ' '___')

# One definition of "a session of ours": an aigent- session started in this directory.
# The menu and the kill both ask through here.
#
# Not the name, because the name cannot answer it. `aigent-foo-2` is equally "foo's
# second agent" and "project foo-2's first", and reading it as the former let the picker
# list — and ctrl-x kill — another project's live session. The exact name is no better:
# ~/a/foo and ~/b/foo both want aigent-foo, so whoever launched second sits on
# aigent-foo-2 and the name says nothing about which of them owns it.
#
# So ask tmux where the session was started: launch() passes -c "$PWD" and tmux keeps it
# verbatim as #{session_path}. Exact, needs no bookkeeping of our own, and already true
# of every session started before this rule existed.
#
# The prefix check leads and does the refusing — a "new  claude" row reaches kill_session
# as the agent name and must not resolve to a session at all. No "=" on -t: unlike
# has-session, display-message ignores it and silently answers nothing (same trap as
# set-option, see launch()). Safe without: these names always come from a live
# list-sessions, so an exact match exists and wins.
is_ours() {
  case $1 in
    "$PREFIX"*) ;;
    *) return 1 ;;
  esac
  [ "$(tmux display-message -pt "$1" '#{session_path}' 2>/dev/null)" = "$PWD" ]
}

# Wrap the agent in tmux everywhere except inside tmux itself, where the process is
# persistent anyway and nesting would double every prefix key.
USE_TMUX=
if [ -z "$TMUX" ] && command -v tmux >/dev/null 2>&1; then
  USE_TMUX=1
fi

TAB=$(printf '\t')

# Agents running here. ("Zed reconnected" and "give me a second agent" are
# indistinguishable from here, so show what's running and let you choose.)
#
# Three labels answering three questions:
#   @agent      what is running (claude, cursor, claude/plan). launch() wrote it down;
#               falls back to the process name for a session we did not start.
#   $TASK_FMT   what it's working on — the agent's own session name, published as the
#               terminal title (OSC 2) and exposed by tmux as pane_title. Claude Code
#               puts its /resume summary there.
#   status      whether it's working or wants you back — see live_sessions below.
#
# TASK_FMT defends against two things: tmux seeds pane_title with the *hostname*, so
# "has a title" is not "is non-empty" (an unset pane reads back `airbochs`); and Claude
# Code prefixes an animated spinner glyph, so the leading glyph is stripped. A title
# with no glyph and no space (opencode's "OpenCode") survives whole.
TASK_FMT='#{=45:#{?#{==:#{pane_title},#{host}},,#{s|^[^ ]+ ||:pane_title}}}'

# ─── Is this agent working, or does it want you? ─────────────────────────────
# The question the picker exists to answer, and "wants you" is the only reason you
# opened it. tmux's session_attached is a fact about your terminal, not the agent —
# every session here reads "attached" whether mid-edit or sat on a finished turn.
#
# The signal is the screen, and it's agent-agnostic: every one of these TUIs animates
# while it works (spinner, token count, timer), so a working pane's screen differs
# 300ms later and a stopped one's is byte-identical. A permission prompt doesn't
# animate (the blinking cursor is drawn by the terminal, not the pty). So: hash the
# screen, wait, hash again.
#
# That's why there are no hooks. Claude Code's Stop/PermissionRequest hooks would
# report this exactly — and only for Claude; cursor-agent, opencode and antigravity
# have nothing, so a hook-built status would light one row and leave the rest blank.
# Repainting a pty is the one thing all four already do.
#
# And not a tmux timestamp: #{session_activity} tracks tmux's sticky alert bookkeeping,
# not pty bytes — a detached pane printing every 200ms still had its "activity" age
# grow 0 → 3 → 5s. Two captures is the honest way, and costs one sleep for the list.
#
#   working   the screen changed across the gap
#   blocked   still, and the bottom is asking you a question
#   waiting   still, and not asking — finished its turn, your move
#
# blocked-vs-waiting is the one heuristic: it greps the screen, so an agent that prints
# "Approve" can fool it. Both mean "wants you" and sort above working, so a wrong guess
# costs a colour. AGENT_ASK_RE overrides the pattern for an agent that asks in other words.
#
# AGENT_SETTLE is the gap, and the whole latency this adds. It must outlast the slowest
# repaint of a *working* agent; real ones spin at ~10Hz (Claude repainted on 5/5 samples
# 300ms apart), so 0.35 has room. The error is one-sided by construction: guessing
# working needs both samples to differ, so a still screen can never read as working. The
# bad case is a slow agent shown waiting (you open it and it's busy); a stopped agent
# hidden under "working" cannot happen.
SETTLE=${AGENT_SETTLE:-0.35}
ASK_RE=${AGENT_ASK_RE:-'Do you want|Would you like|Allow |Approve|\[y/[nN]\]|\(y/[nN]\)|❯ +[0-9]\.'}

RED=$(printf '\033[31m')
YEL=$(printf '\033[33m')
DIM=$(printf '\033[2m')
RST=$(printf '\033[0m')

# The *visible* screen only (no -S): a question is on screen by definition, and
# scrollback would turn old questions into current ones.
#
# Both samples must hash through the identical pipeline or every session reads as
# working forever: `$(screen_of x)` strips the capture's trailing blank rows (command
# substitution eats trailing newlines) and piping straight to cksum does not, so the
# two passes hashed different bytes. screen_hash takes the *content*, so both callers
# normalise the same way by construction.
screen_of() { tmux capture-pane -pt "$1" 2>/dev/null; }
screen_hash() { printf '%s\n' "$1" | cksum; }

# Every agent session on the box, TSV: name, agent, task. Unclassified and unfiltered —
# is_ours narrows it to this project for the picker, `aigent status` keeps the lot.
sessions() {
  tmux list-sessions -F \
    "#{session_name}|#{?@agent,#{@agent},#{pane_current_command}}|$TASK_FMT" 2>/dev/null |
    while IFS='|' read -r name label task; do
      case $name in
        "$PREFIX"*) printf '%s\t%s\t%s\n' "$name" "$label" "$task" ;;
        *) ;; # a tmux session you started yourself — not ours to report on
      esac
    done
}

# stdin: name/agent/task. stdout: the same with a state in front. The sleep is paid
# once for the whole list: hash every screen, wait, hash every screen again.
classify() {
  rows=$(cat)
  [ -n "$rows" ] || return 0

  before=$(printf '%s\n' "$rows" | cut -f1 | while read -r name; do
    printf '%s\t%s\n' "$name" "$(screen_hash "$(screen_of "$name")")"
  done)
  sleep "$SETTLE"

  printf '%s\n' "$rows" | while IFS="$TAB" read -r name label task; do
    now=$(screen_of "$name")
    was=$(printf '%s\n' "$before" | awk -F"$TAB" -v n="$name" '$1 == n { print $2 }')

    if [ "$(screen_hash "$now")" != "$was" ]; then
      state=working
    elif printf '%s\n' "$now" | awk 'NF' | tail -n 15 | grep -Eq "$ASK_RE"; then
      state=blocked
    else
      state=waiting
    fi
    printf '%s\t%s\t%s\t%s\n' "$state" "$name" "$label" "$task"
  done
}

# `aigent status` — every agent session on this machine, TSV: state, session, agent, task.
# Deliberately not scoped to $PWD: the picker answers "what's running *here*", this
# answers "what did I leave running while I walked away" — the question a notifier asks
# (the SwiftBar plugin swiftbar/.config/swiftbar/plugins/agents.10s.sh is the only caller).
# blocked < waiting < working alphabetically is also most-wants-you first, so plain sort.
status() { sessions | classify | sort; }

# Menu lines are TAB-delimited; fzf draws only field 3 on (--with-nth). Fields 1-2 are
# carried but never drawn: field 1 (verb) is what the dispatch matches for attach-vs-launch,
# field 2 (target) is what ctrl-x reads as {2}. The session name is worth hiding — every
# row is the same project, so `aigent-_dotfiles` repeats identically and in a half-width
# pane pushed the task (the part that differs) off the end. The suffix survives as a `#2` badge.
#
# Sorted by what it wants from you: blocked, waiting, then the ones getting on with it —
# so the agent you have to unblock lands under the cursor.
live_sessions() {
  sessions | while IFS="$TAB" read -r name label task; do
    is_ours "$name" || continue
    printf '%s\t%s\t%s\n' "$name" "$label" "$task"
  done | classify | while IFS="$TAB" read -r state name label task; do
    case $state in
      blocked) rank=0 dot=$RED ;;
      waiting) rank=1 dot=$YEL ;;
      *) rank=2 dot=$DIM ;;
    esac

    # The -N suffix, and only that: is_ours admits any aigent- session started here, so a
    # name that isn't $SESSION-<digits> (one you made by hand) would otherwise badge
    # itself with the whole leftover string.
    n=${name#"$SESSION"}
    n=${n#-}
    case $n in
      '' | *[!0-9]*) n= ;;
      *) ;; # a real -N ordinal, worth a badge
    esac
    [ -n "$n" ] && label="$label · #$n"
    [ -n "$task" ] && task="  $task"
    # Sort key up front, stripped after.
    printf '%s\tattach\t%s\t%s●%s [%s · %s]%s\n' \
      "$rank" "$name" "$dot" "$RST" "$state" "$label" "$task"
  done | sort | cut -f2-
}

# What a session of ours looks like. Everything here is session-scoped, so a tmux
# session you started yourself keeps its own keys, chrome and layout. Applied on create
# *and* on attach, so a session started before any of this existed picks it up next time.
#
# @agent_locked marks "one agent, one pane": a session here *is* an agent (Zed, nvim and
# the picker each treat it as a single view), so a second pane would make all three lie.
# The enforcing lives in tmux.conf, where the split/new-window keys are guarded by
# `if -F '#{@agent_locked}'` — tmux has no before-split-window, so a hook could only
# create the pane then kill it; a guarded key refuses and nothing is created. Deliberate
# routes stay open: `tmux split-window -t <session>`, join-pane (fires no hook), and the
# prefix + < / > context menus.
#
# No status bar: it would spend the bottom row on a session name you already know, a
# clock, and a one-window list. No pane border either — tmux.conf sets pane-border-status
# top *globally* (useful in a grid), but an agent session is a single pane, so that label
# is dead weight costing a line of height. Both overridden per-session, so a grid you
# build yourself keeps them.
apply_policy() {
  tmux set-option -t "$1" @agent_locked 1
  tmux set-option -t "$1" status off
  tmux set-option -t "$1" pane-border-status off
}

next_free() {
  tmux has-session -t "=$SESSION" 2>/dev/null || {
    printf '%s' "$SESSION"
    return
  }
  n=2
  while tmux has-session -t "=$SESSION-$n" 2>/dev/null; do
    n=$((n + 1))
  done
  printf '%s-%s' "$SESSION" "$n"
}

# ─── Picker internals (invoked by fzf, one process each) ─────────────────────
# These are subcommands rather than shell inline in the fzf flags: fzf single-quotes
# every placeholder and runs the result through $SHELL, where zsh expands a bare leading
# `=` to a command path — both traps silently ate the kill. As subcommands they're plain
# shell and directly testable: `aigent --kill <name>`.

# ctrl-x: kill the highlighted session. Sessions outlive the terminal that started them,
# so nothing else ever reaps them. is_ours guards it: a "new  default" row would otherwise
# hand us the agent name and try to kill a session literally called "default".
kill_session() {
  is_ours "$1" || return 0
  tmux kill-session -t "=$1" 2>/dev/null
}

# Sessions already running here, then the agents you can start. `aigent new` skips to the
# new-session half. Re-run by fzf after a kill, hence a subcommand.
print_menu() {
  agents=$(available_agents)
  [ -n "$agents" ] || {
    echo "aigent: no agent CLIs found on PATH" >&2
    exit 1
  }
  running=
  [ -n "$USE_TMUX" ] && [ -z "$FORCE_NEW" ] && running=$(live_sessions)
  # `$(...)` eats trailing newlines, so re-add one or the last session line welds
  # itself onto the first agent line.
  [ -n "$running" ] && printf '%s\n' "$running"
  # Same three fields: verb, target, what's drawn.
  printf '%s\n' "$agents" | awk -v OFS='\t' '{ print "new", $0, "new     " $0 }'
}

# ─── Launch ──────────────────────────────────────────────────────────────────
# How long to give an agent to fall over before assuming it came up, and the whole cost of
# the dead-on-arrival guard in launch() — every launch that works waits this long before
# attaching.
#
# It buys margin over a real measurement: cursor-agent with no keychain took 350ms and
# 650ms to die on two runs, and a bare `echo; exit 1` took 350-450ms, most of it process
# startup rather than the failure itself. So a value near the measurement is not safe —
# 0.5 sat inside the range and let the very failure this exists for through. 1.5 is ~2.3x
# the slowest seen.
#
# Guessing low is not a cheap mistake, which is what pushed this up rather than down: the
# check turns remain-on-exit back off, so an agent dying just after the deadline has its
# session torn down with the error inside it — the exact silence this guard removes. A
# death later than this reads as a normal exit and you are back to today's behaviour, so
# the guard only ever adds.
BOOT=1.5

# Created detached, stamped with @agent, then attached — not a single new-session, which
# would exec away before we could set the option. @agent records which entry you picked so
# the picker can label the session without inspecting it: claude reports `claude.exe`,
# cursor-agent reports bare `node`, only opencode sets a pane title.
launch() {
  row=$(agent_row "$1")
  [ -n "$row" ] || {
    echo "aigent: unknown agent '$1'" >&2
    exit 1
  }
  cmd=${row#*|}
  args=${cmd#*|}
  cmd=${cmd%%|*}

  # Skip-permissions mode runs any command unconfirmed, so refuse the two places that
  # would be catastrophic.
  if [ "$1" = claude/yolo ]; then
    [ "$(id -u)" -eq 0 ] && {
      echo "aigent: refusing yolo as root" >&2
      exit 1
    }
    [ "$PWD" = "$HOME" ] && {
      echo "aigent: refusing yolo in \$HOME — cd into a project directory" >&2
      exit 1
    }
  fi

  # $args is a controlled, space-separated field from the table above; splitting it into
  # separate arguments is the point.
  # shellcheck disable=SC2086
  [ -n "$USE_TMUX" ] || exec "$cmd" $args

  SESSION=$(next_free)
  # No "=" prefix on set-option: it does not accept one and fails with `no such session:
  # =name` (attach-session and has-session do accept it). Safe anyway — we just created
  # this exact name.
  #
  # remain-on-exit keeps the pane after the agent exits, so the guard below can read why.
  # Chained into new-session's own command list rather than set by a second tmux call: an
  # agent that dies in milliseconds is reaped before a follow-up call can land, which is
  # the exact case worth catching. remain-on-exit-format '' drops tmux's own "Pane is
  # dead" banner, leaving the capture to be the agent's words and nothing else.
  # shellcheck disable=SC2086
  tmux new-session -d -s "$SESSION" -c "$PWD" "$cmd" $args \
    \; set-option -w -t "$SESSION" remain-on-exit on \
    \; set-option -w -t "$SESSION" remain-on-exit-format '' || exit 1
  tmux set-option -t "$SESSION" @agent "$1"

  # Dead on arrival. tmux drops a session the moment its command exits and the error goes
  # with it, so an agent that can't start (bad token, no keychain) made aigent look like it
  # simply did nothing — the failure and a successful launch were both silence. Print what
  # the agent said rather than attaching to a corpse.
  #
  # -S- to read history, unlike screen_of(): a dying pane scrolls its output up out of the
  # visible screen, so the last thing it said is only in the scrollback.
  sleep "$BOOT"
  if [ "$(tmux display-message -pt "$SESSION" '#{pane_dead}' 2>/dev/null)" = 1 ]; then
    echo "aigent: $1 exited immediately (status $(tmux display-message -pt "$SESSION" '#{pane_dead_status}' 2>/dev/null))" >&2
    tmux capture-pane -pS- -t "$SESSION" 2>/dev/null | awk 'NF' | tail -n 15 >&2
    tmux kill-session -t "=$SESSION" 2>/dev/null
    exit 1
  fi
  # Survived, so back to the default: quitting the agent should close the session, not
  # leave a dead pane the picker would keep listing.
  tmux set-option -w -t "$SESSION" remain-on-exit off

  apply_policy "$SESSION"
  exec tmux attach-session -t "=$SESSION"
}

# Stage + commit via the commit-commands plugin's /commit skill. Print mode (-p): a
# one-shot action, not a session. Plain -p only prints the final result — real progress
# needs --output-format stream-json, piped through jq into per-tool-call lines.
commit() {
  claude -p --verbose --output-format stream-json "/commit $*" | jq -rj '
    if .type == "assistant" then
      (.message.content[]? | select(.type == "tool_use")
        | "→ " + .name + ": " + (.input.description // .input.command // (.input | tostring)) + "\n")
    elif .type == "user" then
      (.message.content[]? | select(.type == "tool_result")
        | "  " + (if .is_error then "✗ " else "✓ " end)
        + ((.content | if type == "string" then . else tostring end) | .[0:200]) + "\n")
    elif .type == "result" then
      "\n✔ " + .result + "\n"
    else empty end
  '
}

# ─── Dispatch ────────────────────────────────────────────────────────────────
FORCE_NEW=
case $1 in
  commit)
    shift
    commit "$@"
    exit $?
    ;;
  new) FORCE_NEW=1 ;;
  status)
    status
    exit 0
    ;;
  --print-menu)
    print_menu
    exit 0
    ;;
  --kill)
    kill_session "$2"
    exit 0
    ;;
  '') ;;
  *)
    echo "aigent: unknown argument '$1'" >&2
    exit 1
    ;;
esac

MENU=$(print_menu) || exit 1

# --height=~80%: hug the content, capped at 80%, so three sessions don't open a
# full-screen box. --wrap because a task is a sentence and a narrow pane (Zed's terminal,
# nvim's right panel) can run past the edge — wrapping costs a row and shows all of it,
# where truncating would hide the field that tells two sessions of one project apart.
set -- --prompt='Agent: ' --reverse --no-info --ansi --wrap \
  --delimiter='\t' --with-nth='3..' --height=~80%
if printf '%s\n' "$MENU" | grep -q '^attach'; then
  set -- "$@" --header='enter: attach/start   ctrl-x: kill session' \
    --bind="ctrl-x:execute-silent($0 --kill {2})+reload($0 --print-menu)"
fi

choice=$(printf '%s\n' "$MENU" | fzf "$@") || exit 0

# Field 2 is the target either way — a session name to attach to, or an agent to start.
# cut splits on TAB by default, the delimiter the menu is built with.
target=$(printf '%s' "$choice" | cut -f2)

case $choice in
  attach*)
    apply_policy "$target"
    exec tmux attach-session -t "=$target"
    ;;
  *) launch "$target" ;;
esac
