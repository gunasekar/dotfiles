#!/usr/bin/env sh
# fzf agent picker. Used as `aigent` from any shell, as nvim's right-panel agent
# terminal command (lua/plugins/agents.lua), and as Zed's agent.terminal_init_command.
#
#   aigent                  pick a running session to rejoin, or an agent to start
#   aigent new              skip the running sessions, start a fresh one
#   aigent status           every agent session on the box — a table on a terminal, TSV
#                           when piped, for a notifier to read
#   aigent cockpit [N]      several agents at once in one window. Pick them, or take the
#                           N that most want you. Bare `cockpit` re-attaches to a cockpit
#                           already up rather than rebuilding; `cockpit new` forces a fresh
#                           pick. Inside, all stock tmux: C-b ←↑↓→ move, C-b z zoom one
#                           full-screen, C-b Space cycle layout, C-b d detach. C-b C-b s
#                           re-points one pane at a different agent — C-b C-b is send-prefix,
#                           so the key lands on the pane's own (inner) client rather than on
#                           the cockpit.
#
# Env:
#   AGENT_SETTLE           seconds between the two screen samples (default 0.35)
#   AGENT_ASK_RE           regex meaning "the agent is asking you something"
#
# `aigent`, not `agent`: ~/.local/bin is a shared namespace, and cursor-agent ships
# a binary called `agent` that overwrote this script's symlink on install and on
# every self-update. Owning a name a vendor also wants is a fight you re-lose on
# every update, so don't share it.
#
# Sessions live in tmux, one per agent, named aigent-<project>. $PREFIX below is the
# only definition of "a session of ours", so changing it orphans anything already
# running — rename live sessions rather than strand them:
#   tmux rename-session -t agent-foo aigent-foo
#
# Why tmux: Zed's remote mode runs this on the ssh host, and when Zed disconnects the
# agent process dies with its terminal, leaving `claude --resume` (which replays the
# transcript into a *new* process) as the only way back. Held in tmux the process
# stays alive, so reconnecting re-attaches to the running conversation with nothing to
# resume. Every frontend goes through this one script; the same session is reachable
# from a plain terminal with `tmux a -t aigent-<project>`.

# ─── Agent registry ──────────────────────────────────────────────────────────
# name|command|args — the single source of truth. Drives the menu, the PATH filter
# and the launch, so adding an agent is one line here and nothing else.
#
# Every agent starts in its normal, permission-prompting mode. The 4th field is the flag that
# turns that agent's "run every command unconfirmed" mode on, and it is opt-in per launch:
# Tab in the picker arms the highlighted row (it relabels to "(YOLO)"), and Enter then starts
# that one session with the flag appended. Nothing is armed unless you Tab it, so a stray
# Enter is always the safe mode. The flag lives here rather than baked into the command
# because the mode is a pick-time choice now — not a fixed property of a row.
#
# Each CLI spells the flag differently, which is the whole reason it is a per-agent field:
#   claude       --dangerously-skip-permissions
#   cursor       --force   (alias --yolo — allow every command unless explicitly denied)
#   opencode     --auto    (auto-approve permissions not explicitly denied)
#   antigravity  --dangerously-skip-permissions   (agy — Google reused claude's flag name)
# pi is the exception that needs no flag: it has no permission gating at all — "no permission
# popups" by design (its README) — so the plain "new  pi" row already runs tools unconfirmed and
# there is nothing for a flag to switch on. Its field is empty like a flagless agent's, so Tab is
# a no-op, but the reason is the opposite — pi is *always* in the mode YOLO would grant, not
# missing it. (pi's own --approve only trusts project-local config files, never tool calls.)
# agy is not installed on this box, so its flag comes from Google's CLI docs, not a live --help.
# launch() refuses a YOLO launch as root when the flag is --dangerously-skip-permissions (claude
# and agy): that flag also auto-approves the sandbox-bypass prompt, so skip-permissions plus root
# is the one combination catastrophic enough to guard (see there); plain, prompting mode needs none.
AGENTS='claude|claude||--dangerously-skip-permissions
cursor|cursor-agent||--force
antigravity|agy||--dangerously-skip-permissions
opencode|opencode||--auto
pi|pi||'

agent_row() {
  printf '%s\n' "$AGENTS" | awk -F'|' -v n="$1" '$1 == n { print; exit }'
}

# The flag that turns on an agent's YOLO (run-everything-unconfirmed) mode — the 4th field,
# empty for an agent that has none. toggle_yolo and launch both ask through here, so "which
# agents can be armed" has a single answer and a session name (an attach row) simply misses.
yolo_flag() {
  agent_row "$1" | awk -F'|' '{ print $4 }'
}

# Only offer an agent whose command actually exists here.
available_agents() {
  printf '%s\n' "$AGENTS" | while IFS='|' read -r name cmd _; do
    command -v "$cmd" >/dev/null 2>&1 && printf '%s\n' "$name"
  done
}

# ─── This project's sessions ─────────────────────────────────────────────────
# The one place the session prefix is spelled. sessions() and is_ours() both read it
# from here rather than hard-coding the string — two copies is two chances to rename
# only one of them.
PREFIX=aigent-

# tmux forbids '.' and ':' in session names (both are target separators), and spaces
# make `tmux a -t <name>` a quoting chore. Two projects sharing a basename both want
# this name; the loser lands on an -N sibling and is_ours tells them apart by path.
SESSION=$PREFIX$(basename "$PWD" | tr ':. ' '___')

# One definition of "a session of ours": an aigent- session started in this directory.
# The menu and the kill both ask through here.
#
# Not the name, because the name cannot answer it. `aigent-foo-2` is equally "foo's
# second agent" and "project foo-2's first", and reading it as the former let the picker
# list — and ctrl-x kill — another project's live session. The exact name is no better:
# ~/a/foo and ~/b/foo both want aigent-foo, so whoever launched second sits on
# aigent-foo-2 and the name says nothing about which of them owns it.
#
# So ask tmux where the session was started: launch() passes -c "$PWD" and tmux keeps it
# verbatim as #{session_path}. Exact, needs no bookkeeping of our own, and already true
# of every session started before this rule existed.
#
# The prefix check leads and does the refusing — a "new  claude" row reaches kill_session
# as the agent name and must not resolve to a session at all. No "=" on -t: unlike
# has-session, display-message ignores it and silently answers nothing (same trap as
# set-option, see launch()). Safe without: these names always come from a live
# list-sessions, so an exact match exists and wins.
is_ours() {
  case $1 in
    "$PREFIX"*) ;;
    *) return 1 ;;
  esac
  [ "$(tmux display-message -pt "$1" '#{session_path}' 2>/dev/null)" = "$PWD" ]
}

# Wrap the agent in tmux everywhere except inside tmux itself, where the process is
# persistent anyway and nesting would double every prefix key.
USE_TMUX=
if [ -z "$TMUX" ] && command -v tmux >/dev/null 2>&1; then
  USE_TMUX=1
fi

TAB=$(printf '\t')

# Agents running here. ("Zed reconnected" and "give me a second agent" are
# indistinguishable from here, so show what's running and let you choose.)
#
# Three labels answering three questions:
#   @agent      what is running (claude, cursor, opencode). launch() wrote it down;
#               falls back to the process name for a session we did not start.
#   $TASK_FMT   what it's working on — the agent's own session name, published as the
#               terminal title (OSC 2) and exposed by tmux as pane_title. Claude Code
#               puts its /resume summary there.
#   status      whether it's working or wants you back — see live_sessions below.
#
# TASK_FMT defends against two things: tmux seeds pane_title with the *hostname*, so
# "has a title" is not "is non-empty" (an unset pane reads back `airbochs`) — compared
# against #{host} and not #{host_short}, because that seed is gethostname() verbatim and
# the two differ wherever the box answers with an FQDN; and Claude Code prefixes an
# animated spinner glyph, so a leading glyph is stripped.
#
# "Glyph" has to be spelled out rather than taken as "whatever comes first". `^[^ ]+ `
# ate the first word of any title that had one — "Fixing the flaky test" displayed as
# "the flaky test", and a quoted opener lost the quote and the word inside it. Barring
# alphanumerics from the run confines it to decoration: every Claude title (✳, ⠂) still
# loses its glyph, and a title that opens with a plain word now survives whole, as one
# with no glyph and no space (opencode's "OpenCode") always did.
TASK_FMT='#{=45:#{?#{==:#{pane_title},#{host}},,#{s|^[^A-Za-z0-9 ]+ ||:pane_title}}}'

# ─── Is this agent working, or does it want you? ─────────────────────────────
# The question the picker exists to answer, and "wants you" is the only reason you
# opened it. tmux's session_attached is a fact about your terminal, not the agent —
# every session here reads "attached" whether mid-edit or sat on a finished turn.
#
# The signal is the screen, and it's agent-agnostic: every one of these TUIs animates
# while it works (spinner, token count, timer), so a working pane's screen differs
# 300ms later and a stopped one's is byte-identical. A permission prompt doesn't
# animate (the blinking cursor is drawn by the terminal, not the pty). So: hash the
# screen, wait, hash again.
#
# That's why there are no hooks. Claude Code's Stop/PermissionRequest hooks would
# report this exactly — and only for Claude; cursor-agent, opencode and antigravity
# have nothing, so a hook-built status would light one row and leave the rest blank.
# Repainting a pty is the one thing all four already do.
#
# And not a tmux timestamp: #{session_activity} tracks tmux's sticky alert bookkeeping,
# not pty bytes — a detached pane printing every 200ms still had its "activity" age
# grow 0 → 3 → 5s. Two captures is the honest way, and costs one sleep for the list.
#
#   working   the screen changed across the gap
#   blocked   still, and the bottom is asking you a question
#   idle      still, and not asking — finished its turn, your move
#
# blocked-vs-idle is the one heuristic: it greps the screen, so an agent that prints
# "Approve" can fool it. Both mean "wants you" and sort above working, so a wrong guess
# costs a colour. AGENT_ASK_RE overrides the pattern for an agent that asks in other words.
#
# AGENT_SETTLE is the gap, and the whole latency this adds. It must outlast the slowest
# repaint of a *working* agent; real ones spin at ~10Hz (Claude repainted on 5/5 samples
# 300ms apart), so 0.35 has room. The error is one-sided by construction: guessing
# working needs both samples to differ, so a still screen can never read as working. The
# bad case is a slow agent shown idle (you open it and it's busy); a stopped agent
# hidden under "working" cannot happen.
SETTLE=${AGENT_SETTLE:-0.35}
ASK_RE=${AGENT_ASK_RE:-'Do you want|Would you like|Allow |Approve|\[y/[nN]\]|\(y/[nN]\)|❯ +[0-9]\.'}

RED=$(printf '\033[31m')
YEL=$(printf '\033[33m')
DIM=$(printf '\033[2m')
RST=$(printf '\033[0m')

# The *visible* screen only (no -S): a question is on screen by definition, and
# scrollback would turn old questions into current ones.
#
# Both samples must hash through the identical pipeline or every session reads as
# working forever: `$(screen_of x)` strips the capture's trailing blank rows (command
# substitution eats trailing newlines) and piping straight to cksum does not, so the
# two passes hashed different bytes. screen_hash takes the *content*, so both callers
# normalise the same way by construction.
screen_of() { tmux capture-pane -pt "$1" 2>/dev/null; }
screen_hash() { printf '%s\n' "$1" | cksum; }

# Every agent session on the box, TSV: name, agent, task. Unclassified and unfiltered —
# is_ours narrows it to this project for the picker, `aigent status` keeps the lot.
sessions() {
  tmux list-sessions -F \
    "#{session_name}|#{?@agent,#{@agent},#{pane_current_command}}|$TASK_FMT" 2>/dev/null |
    while IFS='|' read -r name label task; do
      case $name in
        "$PREFIX"*) printf '%s\t%s\t%s\n' "$name" "$label" "$task" ;;
        *) ;; # a tmux session you started yourself — not ours to report on
      esac
    done
}

# stdin: name/agent/task. stdout: the same with a state in front. The sleep is paid
# once for the whole list: hash every screen, wait, hash every screen again.
classify() {
  rows=$(cat)
  [ -n "$rows" ] || return 0

  before=$(printf '%s\n' "$rows" | cut -f1 | while read -r name; do
    printf '%s\t%s\n' "$name" "$(screen_hash "$(screen_of "$name")")"
  done)
  sleep "$SETTLE"

  printf '%s\n' "$rows" | while IFS="$TAB" read -r name label task; do
    now=$(screen_of "$name")
    was=$(printf '%s\n' "$before" | awk -F"$TAB" -v n="$name" '$1 == n { print $2 }')

    if [ "$(screen_hash "$now")" != "$was" ]; then
      state=working
    elif printf '%s\n' "$now" | awk 'NF' | tail -n 15 | grep -Eq "$ASK_RE"; then
      state=blocked
    else
      state=idle
    fi
    printf '%s\t%s\t%s\t%s\n' "$state" "$name" "$label" "$task"
  done
}

# state → sort rank and colour: blocked first and red, idle next and yellow, working last
# and dim. Both shell menus (live_sessions, cockpit_menu) draw the same rows in the same
# order, so they read the mapping from here rather than each carrying a copy — a fourth
# state added to classify() lands in one place, not two.
#
# status() keeps its own copy in awk, and has to: it draws a padded table, so it is already
# in awk by the time it needs a colour, and a shell callout per row to fetch one would be
# absurd. That is why the state *names* are the contract between the two (see status()).
#
# Sets $rank and $dot rather than printing them: two values, and sh gives a function one
# stdout. Both callers consume them on the next line, so the reach is a line long.
rank_dot() {
  case $1 in
    blocked) rank=0 dot=$RED ;;
    idle) rank=1 dot=$YEL ;;
    *) rank=2 dot=$DIM ;;
  esac
}

# `aigent status` — every agent session on this machine: state, session, agent, task.
# Deliberately not scoped to $PWD: the picker answers "what's running *here*", this
# answers "what did I leave running while I walked away" — the question a notifier asks
# (the SwiftBar plugin swiftbar/.config/swiftbar/plugins/agents.10s.sh is the only caller).
# blocked < idle < working alphabetically is also most-wants-you first, so plain sort. The
# coincidence is load-bearing: renaming a state re-rolls it, and a name that sorts wrong
# re-orders the notifier's rows quietly rather than failing.
#
# Two audiences, so two views. The TSV is a contract — the plugin reads it back with
# `IFS=$'\t' read -r state name agent task` — but a tab is not a column: it jumps to the
# terminal's next 8-stop, so the moment one session name is longer than another the fields
# stop lining up and you are reading a ragged grid. A person wants columns; a notifier
# wants fields. `[ -t 1 ]` separates them, and needs no flag to do it: the plugin's own
# `$(...)` is a pipe, so it goes on getting the TSV whether or not it ever asks.
status() {
  rows=$(sessions | classify | sort)
  [ -n "$rows" ] || return 0
  [ -t 1 ] || {
    printf '%s\n' "$rows"
    return 0
  }

  # Widths measured off the widest cell rather than fixed, so nothing truncates and
  # nothing is padded further than this particular set of sessions needs.
  #
  # The name sheds $PREFIX and nothing else. Splitting a trailing -2 off as a `#2` badge
  # is what the picker does, and it can: is_ours has already established every row there
  # is the same project, so the suffix is an ordinal. Here the rows are the whole box,
  # where `aigent-foo-2` is equally foo's second agent and project foo-2's only one — the
  # same ambiguity is_ours stopped guessing at. So print the name and let it be read.
  printf '%s\n' "$rows" | awk -F"$TAB" \
    -v pfx="$PREFIX" -v red="$RED" -v yel="$YEL" -v dim="$DIM" -v rst="$RST" '
    {
      st[NR] = $1; ag[NR] = $3; tk[NR] = $4
      nm[NR] = $2
      if (index(nm[NR], pfx) == 1) nm[NR] = substr(nm[NR], length(pfx) + 1)
      if (length(st[NR]) > w1) w1 = length(st[NR])
      if (length(nm[NR]) > w2) w2 = length(nm[NR])
      if (length(ag[NR]) > w3) w3 = length(ag[NR])
    }
    END {
      for (i = 1; i <= NR; i++) {
        c = st[i] == "blocked" ? red : (st[i] == "idle" ? yel : dim)
        # Built whole then trimmed: a session with no task would otherwise leave the
        # agent column padded out to nothing.
        line = sprintf("%-*s  %-*s  %-*s  %s", w1, st[i], w2, nm[i], w3, ag[i], tk[i])
        sub(/ +$/, "", line)
        printf "%s●%s %s\n", c, rst, line
      }
    }
  '
}

# Menu lines are TAB-delimited; fzf draws only field 3 on (--with-nth). Fields 1-2 are
# carried but never drawn: field 1 (verb) is what the dispatch matches for attach-vs-launch,
# field 2 (target) is what ctrl-x reads as {2}. The session name is worth hiding — every
# row is the same project, so `aigent-_dotfiles` repeats identically and in a half-width
# pane pushed the task (the part that differs) off the end. The suffix survives as a `#2` badge.
#
# Sorted by what it wants from you: blocked, idle, then the ones getting on with it —
# so the agent you have to unblock lands under the cursor.
live_sessions() {
  sessions | while IFS="$TAB" read -r name label task; do
    is_ours "$name" || continue
    printf '%s\t%s\t%s\n' "$name" "$label" "$task"
  done | classify | while IFS="$TAB" read -r state name label task; do
    rank_dot "$state"

    # The -N suffix, and only that: is_ours admits any aigent- session started here, so a
    # name that isn't $SESSION-<digits> (one you made by hand) would otherwise badge
    # itself with the whole leftover string.
    n=${name#"$SESSION"}
    n=${n#-}
    case $n in
      '' | *[!0-9]*) n= ;;
      *) ;; # a real -N ordinal, worth a badge
    esac
    [ -n "$n" ] && label="$label · #$n"
    [ -n "$task" ] && task="  $task"
    # Sort key up front, stripped after.
    printf '%s\tattach\t%s\t%s●%s [%s · %s]%s\n' \
      "$rank" "$name" "$dot" "$RST" "$state" "$label" "$task"
  done | sort | cut -f2-
}

# What a session of ours looks like. Everything here is session-scoped, so a tmux
# session you started yourself keeps its own keys, chrome and layout. Applied on create
# *and* on attach, so a session started before any of this existed picks it up next time.
#
# @agent_locked marks "one agent, one pane": a session here *is* an agent (Zed, nvim and
# the picker each treat it as a single view), so a second pane would make all three lie.
# The enforcing lives in tmux.conf, where the split/new-window keys are guarded by
# `if -F '#{@agent_locked}'` — tmux has no before-split-window, so a hook could only
# create the pane then kill it; a guarded key refuses and nothing is created. Deliberate
# routes stay open: `tmux split-window -t <session>`, join-pane (fires no hook), and the
# prefix + < / > context menus.
#
# No status bar: it would spend the bottom row on a session name you already know, a
# clock, and a one-window list. No pane border either — tmux.conf sets pane-border-status
# top *globally* (useful in a grid), but an agent session is a single pane, so that label
# is dead weight costing a line of height. Both overridden per-session, so a grid you
# build yourself keeps them.
apply_policy() {
  tmux set-option -t "$1" @agent_locked 1
  tmux set-option -t "$1" status off
  tmux set-option -t "$1" pane-border-status off
}

next_free() {
  tmux has-session -t "=$SESSION" 2>/dev/null || {
    printf '%s' "$SESSION"
    return
  }
  n=2
  while tmux has-session -t "=$SESSION-$n" 2>/dev/null; do
    n=$((n + 1))
  done
  printf '%s-%s' "$SESSION" "$n"
}

# ─── Picker internals (invoked by fzf, one process each) ─────────────────────
# These are subcommands rather than shell inline in the fzf flags: fzf single-quotes
# every placeholder and runs the result through $SHELL, where zsh expands a bare leading
# `=` to a command path — both traps silently ate the kill. As subcommands they're plain
# shell and directly testable: `aigent --kill <name>`.

# ctrl-x: kill the highlighted session. Sessions outlive the terminal that started them,
# so nothing else ever reaps them. is_ours guards it: a "new  default" row would otherwise
# hand us the agent name and try to kill a session literally called "default".
kill_session() {
  is_ours "$1" || return 0
  tmux kill-session -t "=$1" 2>/dev/null
  # Recompute the cached running block so the reload that follows drops the killed row (and
  # re-reads the survivors' state). Guarded on the cache path so a bare `aigent --kill x` (no
  # picker, path unset) skips it. This is the one reload that pays classify's settle sleep, and
  # it should: a kill is rare and wants fresh state — unlike a Tab, which only relabels.
  [ -n "$AIGENT_MENU_CACHE" ] && live_sessions >"$AIGENT_MENU_CACHE"
}

# tab: arm the highlighted agent for YOLO, or disarm it if it was already armed. Exactly one
# agent can be armed at a time — arming a second replaces the first — so the state is a single
# name in a file, not a set. Only an agent with a YOLO flag can be armed; Tab on an attach row
# (a session name) or a flagless agent (pi, antigravity) finds no flag and is a no-op. The
# file is $AIGENT_YOLO_STATE, exported by the dispatch below and so inherited by this
# subprocess fzf spawns. print_menu reads the same file to relabel the row and set its verb.
toggle_yolo() {
  [ -n "$AIGENT_YOLO_STATE" ] || return 0
  [ -n "$(yolo_flag "$1")" ] || return 0
  cur=
  [ -s "$AIGENT_YOLO_STATE" ] && cur=$(cat "$AIGENT_YOLO_STATE")
  if [ "$cur" = "$1" ]; then
    : >"$AIGENT_YOLO_STATE"
  else
    printf '%s' "$1" >"$AIGENT_YOLO_STATE"
  fi
}

# Sessions already running here, then the agents you can start. `aigent new` skips to the
# new-session half. Re-run by fzf after a kill, hence a subcommand.
print_menu() {
  agents=$(available_agents)
  [ -n "$agents" ] || {
    echo "aigent: no agent CLIs found on PATH" >&2
    exit 1
  }
  # The running sessions come from the cache the dispatch classified once, not a fresh
  # live_sessions() here. classify() sleeps AGENT_SETTLE to sample each screen twice, and
  # print_menu is re-run on every Tab and ctrl-x reload — paying that sleep per keystroke is
  # what made the Tab relabel lag. The snapshot is fixed for the picker's life anyway (fzf never
  # live-refreshes it), so caching loses no freshness. An empty cache means no running rows,
  # which is also how `aigent new` and no-tmux reach here — the dispatch reads FORCE_NEW and
  # leaves the file empty, so print_menu need not (and its reload subprocess cannot) see it.
  running=
  [ -n "$AIGENT_MENU_CACHE" ] && [ -s "$AIGENT_MENU_CACHE" ] && running=$(cat "$AIGENT_MENU_CACHE")
  # `$(...)` eats trailing newlines, so re-add one or the last session line welds
  # itself onto the first agent line.
  [ -n "$running" ] && printf '%s\n' "$running"

  # The one agent armed for YOLO (toggle_yolo wrote it); empty if none. Its row carries the
  # verb "yolo" so the dispatch launches it with the flag, and draws "(YOLO)" in yellow so you
  # can see what Enter will do. Every other agent is a plain "new" row.
  armed=
  [ -n "$AIGENT_YOLO_STATE" ] && [ -s "$AIGENT_YOLO_STATE" ] && armed=$(cat "$AIGENT_YOLO_STATE")
  # Same three fields: verb, target, what's drawn.
  printf '%s\n' "$agents" | awk -v OFS='\t' -v armed="$armed" -v yel="$YEL" -v rst="$RST" '
    $0 == armed { print "yolo", $0, "new     " $0 "  " yel "(YOLO)" rst; next }
    { print "new", $0, "new     " $0 }
  '
}

# ─── Launch ──────────────────────────────────────────────────────────────────
# How long to give an agent to fall over before assuming it came up, and the whole cost of
# the dead-on-arrival guard in launch() — every launch that works waits this long before
# attaching.
#
# It buys margin over a real measurement: cursor-agent with no keychain took 350ms and
# 650ms to die on two runs, and a bare `echo; exit 1` took 350-450ms, most of it process
# startup rather than the failure itself. So a value near the measurement is not safe —
# 0.5 sat inside the range and let the very failure this exists for through. 1.5 is ~2.3x
# the slowest seen.
#
# Guessing low is not a cheap mistake, which is what pushed this up rather than down: the
# check turns remain-on-exit back off, so an agent dying just after the deadline has its
# session torn down with the error inside it — the exact silence this guard removes. A
# death later than this reads as a normal exit and you are back to today's behaviour, so
# the guard only ever adds.
BOOT=1.5

# Created detached, stamped with @agent, then attached — not a single new-session, which
# would exec away before we could set the option. @agent records which entry you picked so
# the picker can label the session without inspecting it: claude reports `claude.exe`,
# cursor-agent reports bare `node`, only opencode sets a pane title.
launch() {
  row=$(agent_row "$1")
  [ -n "$row" ] || {
    echo "aigent: unknown agent '$1'" >&2
    exit 1
  }
  # name|command|args|yolo — pull the three we launch with. args is normally empty; the yolo
  # flag is appended only when this launch was armed (see mode below).
  rest=${row#*|}
  cmd=${rest%%|*}
  rest=${rest#*|}
  args=${rest%%|*}
  yolo=${rest#*|}

  # $2 is "yolo" when the picker row was Tab-armed, empty otherwise. A row can only be armed
  # if it has a flag (toggle_yolo enforces it), so the empty-flag branch is belt-and-braces
  # rather than a path the picker can reach.
  if [ "$2" = yolo ]; then
    [ -n "$yolo" ] || {
      echo "aigent: $1 has no YOLO mode" >&2
      exit 1
    }
    args="${args:+$args }$yolo"
  fi

  # Skip-permissions mode runs any command unconfirmed, so refuse the one place left where
  # that is catastrophic rather than merely unwise. $HOME was refused here too until
  # refuse_bad_cwd started refusing it — and / — for every agent before the picker opens,
  # which is both wider and resolves symlinks this never did. Only the yolo launch is refused:
  # plain, prompting mode is merely ordinary as root.
  #
  # Keyed on the flag, not the agent name, so every agent whose YOLO flag is
  # --dangerously-skip-permissions is covered without a list to keep in sync — today claude and
  # antigravity's agy, which reused the name. That flag also auto-approves the sandbox-bypass
  # prompt, which is what makes it (and not --force or --auto) the one worth refusing as root.
  if [ "$2" = yolo ] && [ "$(id -u)" -eq 0 ]; then
    case $yolo in
      *--dangerously-skip-permissions*)
        echo "aigent: refusing $1 --dangerously-skip-permissions as root" >&2
        exit 1
        ;;
    esac
  fi

  # $args is a controlled, space-separated field from the table above; splitting it into
  # separate arguments is the point.
  # shellcheck disable=SC2086
  [ -n "$USE_TMUX" ] || exec "$cmd" $args

  SESSION=$(next_free)
  # No "=" prefix on set-option: it does not accept one and fails with `no such session:
  # =name` (attach-session and has-session do accept it). Safe anyway — we just created
  # this exact name.
  #
  # remain-on-exit keeps the pane after the agent exits, so the guard below can read why.
  # Chained into new-session's own command list rather than set by a second tmux call: an
  # agent that dies in milliseconds is reaped before a follow-up call can land, which is
  # the exact case worth catching. remain-on-exit-format '' drops tmux's own "Pane is
  # dead" banner, leaving the capture to be the agent's words and nothing else.
  # shellcheck disable=SC2086
  tmux new-session -d -s "$SESSION" -c "$PWD" "$cmd" $args \
    \; set-option -w -t "$SESSION" remain-on-exit on \
    \; set-option -w -t "$SESSION" remain-on-exit-format '' || exit 1
  # The picked entry, tagged (YOLO) when armed, so the picker and status table can label the
  # session without inspecting the process. ${2:+ (YOLO)} adds the tag only for a yolo launch.
  tmux set-option -t "$SESSION" @agent "$1${2:+ (YOLO)}"

  # Dead on arrival. tmux drops a session the moment its command exits and the error goes
  # with it, so an agent that can't start (bad token, no keychain) made aigent look like it
  # simply did nothing — the failure and a successful launch were both silence. Print what
  # the agent said rather than attaching to a corpse.
  #
  # -S- to read history, unlike screen_of(): a dying pane scrolls its output up out of the
  # visible screen, so the last thing it said is only in the scrollback.
  sleep "$BOOT"
  if [ "$(tmux display-message -pt "$SESSION" '#{pane_dead}' 2>/dev/null)" = 1 ]; then
    echo "aigent: $1 exited immediately (status $(tmux display-message -pt "$SESSION" '#{pane_dead_status}' 2>/dev/null))" >&2
    tmux capture-pane -pS- -t "$SESSION" 2>/dev/null | awk 'NF' | tail -n 15 >&2
    tmux kill-session -t "=$SESSION" 2>/dev/null
    exit 1
  fi
  # Survived, so back to the default: quitting the agent should close the session, not
  # leave a dead pane the picker would keep listing.
  tmux set-option -w -t "$SESSION" remain-on-exit off

  apply_policy "$SESSION"
  exec tmux attach-session -t "=$SESSION"
}

# ─── Cockpit ─────────────────────────────────────────────────────────────────
# Several agents at once, in one window. The picker answers "what do I open here" and
# status() answers "who wants me"; this is the third question — watch four of them work,
# and answer whichever one stops, without leaving the window.
#
# Every pane is a tmux client attached to a live agent session: the cockpit *borrows* the
# view, it does not take the pane. That is the whole design, and the reason to prefer it
# over join-pane, which is the obvious other way to get four agents into one window.
# join-pane *moves* a pane, so aigent-foo would stop being a session — and sessions are
# what is_ours, status() and the SwiftBar plugin all ask tmux about, so all three would go
# blind at once. A cockpit that died mid-flight would leave the agents merged into a
# session none of them chose, with no way back but hand-run break-pane.
#
# Borrowed, the cockpit owns nothing, so it can lose nothing: kill it, close the window,
# crash it, and every agent is where it was — still running, still attached to whatever
# else was viewing it. That is also why this never reuses a cockpit. Rebuilding is free
# when there is no state to keep, so `aigent cockpit` always builds a fresh one rather
# than reconciling an old one against a new pick.
#
# Not $PWD-scoped, for status()'s reason: the picker asks what is running *here*, the
# cockpit asks what is running *at all*.
#
# What it costs, and it is not nothing. A tmux window has one grid, so a session two
# clients of different shapes are watching cannot be right for both — that is not a thing
# to fix, only a thing to point somewhere. window-size is left at its default `latest`,
# which points it at the most recently *used* client, not the newest one: whichever client
# you last typed in wins, so the view you are working in is always the correct one and the
# other is the one that pays. That is the behaviour worth having, and it is why no attempt
# is made to be cleverer here.
#
# What the other one pays is a re-flow, and two consequences follow. Any *other* window
# viewing that agent — a Zed thread, an nvim panel — draws it small in the corner until
# you press a key there, which re-elects it and snaps it back (measured: 200x49 ↔ 180x44
# across a keypress, either way). And a re-flow is a screen change, so the `aigent status`
# poll that straddles an attach reads those agents as `working` — classify() calls a
# changed screen working by construction — and the SwiftBar plugin re-announces them once
# as they settle. That is the one place the cockpit dents the notifier's one-sided error:
# a still screen can never read as working, and a resize is a still screen that moves
# (measured: capture-pane's content hash does change across a resize). AGENT_NOTIFY_AFTER
# is the existing dial for it, for the same reason it exists at all.
#
# `-f ignore-size` on the pane clients is the other end of the lever and was measured too:
# it holds the agent at the other client's size, keeps typing (it is not read-only, which
# is a separate flag), and falls back to the cockpit's own size when nothing else is
# looking. It is not used because it only moves the dead space into the cockpit pane —
# a session Zed holds at 114x84 renders into a 181x45 pane as 114 columns of agent and 67
# of nothing. Neither end is free, and the active view is the better one to keep whole.

# One name, so exactly one cockpit — a decision, not an oversight, and the difference
# matters because the fix for it is sitting right there in this file. next_free() gives
# agent sessions their -2 because each holds a live conversation that cannot be recreated:
# ~/a/foo and ~/b/foo both want aigent-foo, neither can yield, so they coexist. A cockpit
# holds nothing, so that pressure has no counterpart here — nothing collides, because
# there is nothing to lose. Reaching for next_free() when a second cockpit "collides"
# would be solving a problem the design does not have, and would cost the thing a fixed
# name buys: the cockpit is a *place*. `tmux a -t cockpit` finds it forever, and re-running
# builds over it. Two of them and you are tracking which is which, which is bookkeeping —
# for the one thing here whose whole point is that it needs none.
#
# The axis that scales is panes, not cockpits: eight agents is `aigent cockpit 8`, not two
# cockpits of four. Two monitors would be the honest reason to want a second, and a cockpit
# you keep *while* building another would be a better one — but that second is a saved view,
# which is state, and state is exactly what this does not have and should not grow lightly.
#
# The cost lands on kill-session in cockpit(): a window already sitting in the old cockpit
# has its `tmux attach` exit under it and drops back to a shell. Measured, and in the README,
# because it is the one part of "re-running is free" that is not free. The agents are
# untouched — they always are.
#
# Outside $PREFIX on purpose, and load-bearing rather than taste: sessions() calls
# anything named aigent-* an agent session, so an `aigent-cockpit` would be listed by
# `aigent status` and counted by the notifier as one more agent — a viewer reported as a
# thing to watch, permanently "working" because its panes always repaint. The prefix
# means "an agent lives here", and no agent lives here.
COCKPIT=cockpit

# This is the one session the script kills without asking, so be sure it is ours first.
# @cockpit is the marker, stamped at build; a session you named `cockpit` yourself has no
# marker and gets refused rather than reaped. display-message rather than show-options -t,
# and no "=": the same trap is_ours() documents.
is_cockpit() {
  [ "$(tmux display-message -pt "$COCKPIT" '#{@cockpit}' 2>/dev/null)" = 1 ]
}

# fzf's preview: the agent's own screen. It is what makes a name pickable — "aigent-foundry"
# is a name, the screen tells you it is sat on a permission prompt. -e keeps the colours.
peek() { tmux capture-pane -pet "$1" 2>/dev/null; }

# What a cockpit pane runs: one tmux client, attached to one agent session. Written once
# because both callers (new-session for the first pane, split-window for the rest) need the
# same two non-obvious things, and either one missed is silent.
#
# The quotes around the '=' are for zsh, not tmux. tmux runs a pane's command through
# $SHELL, where a bare leading `=` expands to a command path — the same trap that made the
# picker internals above subcommands. Unquoted, every pane dies on arrival with
# "=aigent-foo not found" and the cockpit comes up empty.
#
# env -u TMUX because tmux sets $TMUX in every pane it creates and refuses to nest while it
# is set. Clearing it is the supported way in: the inner client is an ordinary client that
# happens to have a pane for a terminal. Truecolor and CSI-u both survive the nest and need
# nothing added to tmux.conf — tmux negotiates RGB with the outer tmux at runtime rather
# than trusting tmux-256color's terminfo (which declares neither), and extended-keys is a
# server option, so it is already true of the inner client and Shift+Enter reaches the agent.
view_cmd() { printf "env -u TMUX tmux attach -t '=%s'" "$1"; }

# The directory a cockpit pane's agent works in — its session_path basename, frozen at
# launch by launch()'s -c "$PWD". Stamped onto the pane as @dir so the border can lead
# with it (see the pane-border-format below). Not folded into tmux.conf's set-titles-string,
# which is where "claude · <task>" comes from: that string is also the Ghostty tab title and
# the normal agent session's title, and the directory is wanted in the cockpit grid only.
# Static, unlike the task half — a session's directory cannot change — so it is set once at
# build and never goes stale, where #{pane_title} stays live for the task.
# No "=" on the -t: display-message silently answers nothing for an =exact target (the
# trap is_ours() documents), so "=$1" would hand basename an empty string and every pane
# would get a blank @dir. The name comes straight from a live list, so an unanchored match
# still lands on it exactly.
cockpit_dir() { basename "$(tmux display-message -pt "$1" '#{session_path}' 2>/dev/null)"; }

# The agent name for a cockpit pane, stamped as @ag so the border can tell a real task from
# the title-less fallback. Before an agent publishes a task, tmux.conf's set-titles-string
# falls back to "#{@agent} · #{b:pane_current_path}" — i.e. "claude · <dir>" — so the border
# would read "<dir> · claude · <dir>", the directory twice. The border composes that same
# fallback string from @ag and @dir and, on a match, drops the task half (see below). Same
# no-"=" rule as cockpit_dir, and same source, so @agent is the value launch() wrote.
cockpit_agent() { tmux display-message -pt "$1" '#{@agent}' 2>/dev/null; }

# Every agent on the box, ranked most-wants-you first. The rank is the same blocked/idle/
# working sort status() and live_sessions() use, so pane 1 of the grid is always the one
# to look at first.
#
# The name keeps its -N suffix here, for the reason status() spells out and live_sessions()
# is exempt from: box-wide, `aigent-foo-2` is equally foo's second agent and project
# foo-2's only one, so the `#2` badge would be a guess. Print the name and let it be read.
cockpit_menu() {
  sessions | classify | while IFS="$TAB" read -r state name label task; do
    rank_dot "$state"
    [ -n "$task" ] && task="  $task"
    # Sort key up front, stripped after — leaving name, then what fzf draws.
    printf '%s\t%s\t%s●%s [%s · %s] %s%s\n' \
      "$rank" "$name" "$dot" "$RST" "$state" "$label" "${name#"$PREFIX"}" "$task"
  done | sort | cut -f2-
}

cockpit() {
  command -v tmux >/dev/null 2>&1 || {
    echo "aigent: cockpit needs tmux" >&2
    exit 1
  }
  if tmux has-session -t "=$COCKPIT" 2>/dev/null && ! is_cockpit; then
    echo "aigent: a tmux session named '$COCKPIT' is already here and is not ours" >&2
    echo "        rename it (tmux rename-session -t $COCKPIT <name>) and retry" >&2
    exit 1
  fi

  # Bare `aigent cockpit` means "take me to my cockpit": if one is already up, go there
  # rather than making you re-pick and rebuilding it. The guard above has established that
  # any session named $COCKPIT is ours, so has-session alone is enough here. `aigent cockpit
  # new` skips this to force a fresh pick (it is non-empty, so the -z test is false), and
  # `aigent cockpit N` likewise rebuilds — both keep the stateless "re-running is free"
  # contract; this only spares you the rebuild when you did not ask for one. switch-client
  # inside tmux, attach outside — the same fork the build path ends on.
  if [ -z "${1:-}" ] && tmux has-session -t "=$COCKPIT" 2>/dev/null; then
    [ -z "$TMUX" ] || exec tmux switch-client -t "=$COCKPIT"
    exec tmux attach-session -t "=$COCKPIT"
  fi

  rows=$(cockpit_menu)
  [ -n "$rows" ] || {
    echo "aigent: no agent sessions running" >&2
    exit 1
  }

  # `aigent cockpit N` takes the N that most want you and skips the picker — the rows are
  # already sorted blocked, idle, working, so "the top N" is "the N worth looking at".
  # `aigent cockpit new` opens the picker; bare `aigent cockpit` only reaches here when no
  # cockpit was up to attach to (the block above returns otherwise), so it opens the picker
  # too. Both arrive at the same list of names, and fzf --multi returns them in list order,
  # so the grid stays in wants-you order.
  case ${1:-} in
    '' | new)
      choice=$(printf '%s\n' "$rows" | fzf --multi --reverse --no-info --ansi \
        --prompt='Cockpit: ' --delimiter='\t' --with-nth='2..' --height=~80% \
        --header='tab: pick an agent   enter: open the cockpit' \
        --preview="$0 --peek {1}" --preview-window='right,60%,border-left') || exit 0
      names=$(printf '%s\n' "$choice" | cut -f1)
      ;;
    *[!0-9]*)
      echo "aigent: cockpit takes a number of agents or 'new', not '$1'" >&2
      exit 1
      ;;
    *)
      # 0 reaches head as `head -n 0`, which refuses with "illegal line count" and leaves
      # you reading coreutils' opinion of your typo rather than ours.
      [ "$1" -ge 1 ] || {
        echo "aigent: cockpit needs at least one agent, not '$1'" >&2
        exit 1
      }
      names=$(printf '%s\n' "$rows" | cut -f1 | head -n "$1")
      ;;
  esac
  [ -n "$names" ] || exit 0

  # Drop anything that died between the pick and here. The gap is real: cockpit_menu ran
  # before fzf opened, so a name can be minutes stale by the time you press enter, and an
  # agent that finished and exited in the meantime is gone.
  #
  # It is worth a pass of its own because the first name failing is not survivable. tmux
  # creates the session, its command exits at once, tmux reaps the session — and
  # new-session still returns 0, so the `|| exit 1` below never fires and every call after
  # it ("no such session: cockpit", an empty pane_id, a failed attach) fails in a heap.
  # A dead name later in the list is milder — the pane opens and closes and the grid is
  # quietly one short — but it is the same bug, so it goes the same way.
  #
  # This narrows the window to microseconds rather than closing it; a session dying between
  # this check and the attach still lands in the old behaviour. Nothing can close it — the
  # agent is another process — and narrowing is the whole of the available win.
  names=$(printf '%s\n' "$names" | while read -r n; do
    tmux has-session -t "=$n" 2>/dev/null && printf '%s\n' "$n"
  done)
  [ -n "$names" ] || {
    echo "aigent: the agents you picked are gone" >&2
    exit 1
  }
  count=$(printf '%s\n' "$names" | wc -l | tr -d ' ')

  # Build at the size of the terminal you are standing in, because the layout below is
  # decided on width. A session made without -x/-y sits at tmux's default 80x24 until a
  # client attaches, so the two-pane rule would be judged against a width that is not
  # yours. Inside tmux the client is the window, not the pane, so ask tmux rather than tput.
  if [ -n "$TMUX" ]; then
    size=$(tmux display-message -p '#{client_width} #{client_height}' 2>/dev/null)
  else
    size="$(tput cols 2>/dev/null) $(tput lines 2>/dev/null)"
  fi
  w=${size% *}
  h=${size#* }

  # Fall back to tmux's own default for a client-less session. Neither source is guaranteed
  # to answer: tput says nothing with no TERM or with stdout redirected, and client_width is
  # empty for a $TMUX set with no client attached. Either way the empty string reaches
  # new-session as -x '' and tmux refuses the whole cockpit with a bare "width invalid" —
  # a real answer to a question nobody asked. 80x24 builds something you can look at, and
  # the client that attaches a moment later resizes it to the truth anyway; only the
  # two-pane rule below reads the guess, and it degrades to "stacked".
  case $w in
    '' | *[!0-9]*) w=80 ;;
    *) ;; # a real width, from a real terminal
  esac
  case $h in
    '' | *[!0-9]*) h=24 ;;
    *) ;; # likewise
  esac

  # Three or more is a grid and there is nothing to decide. Two is the case worth thinking
  # about, and it turns on width rather than taste: side by side gives each agent a
  # full-height column, the better shape for reading a conversation — but only if the
  # halves are wide enough to read. Under ~80 columns an agent TUI starts wrapping its own
  # boxes, so a 114-column window (a half-screen Ghostty) is better served stacked: 114
  # wide and short beats 57 wide and tall. Hence 160, which is that 80 doubled. C-b Space
  # cycles if a particular window disagrees.
  if [ "$count" -eq 2 ] && [ "$w" -lt 160 ]; then
    layout=even-vertical
  elif [ "$count" -eq 2 ]; then
    layout=even-horizontal
  else
    layout=tiled
  fi

  # Unconditional, and this is the line that makes "one cockpit" true (see COCKPIT above).
  # A window sitting in the old one loses it here: detach-on-destroy sends its client home,
  # its `tmux attach` exits, and it lands back on a shell. That is the whole cost of asking
  # for a cockpit while one is already open, and it is bounded — the agents never notice,
  # because none of them live here.
  tmux kill-session -t "=$COCKPIT" 2>/dev/null
  first=$(printf '%s\n' "$names" | head -n1)

  tmux new-session -d -s "$COCKPIT" -x "$w" -y "$h" "$(view_cmd "$first")" || exit 1

  # new-session's exit status only says the session was created, not that its command
  # lived: a pane whose command exits immediately takes the session down with it and
  # new-session still returns 0. The filter above makes that unlikely, not impossible, and
  # unnoticed it turns every line below into a "no such session" — so ask.
  tmux has-session -t "=$COCKPIT" 2>/dev/null || {
    echo "aigent: $first went away as the cockpit opened it" >&2
    exit 1
  }
  tmux set-option -t "$COCKPIT" @cockpit 1
  home=$(tmux display-message -pt "$COCKPIT" '#{pane_id}')
  tmux set-option -pt "$home" @dir "$(cockpit_dir "$first")"
  tmux set-option -pt "$home" @ag "$(cockpit_agent "$first")"

  # Re-tile after every split rather than once at the end, because split-window halves the
  # *current* pane and the halves get small fast: measured in an 80x24 window, the fifth
  # agent fails with "no space for new pane" and the cockpit comes up with four and no
  # complaint (the error lands on tmux's stderr, not in the grid you are looking at).
  # Tiling as we go re-spreads the panes each round so the next split has room — the same
  # window then takes six. Four fits either way, which is exactly why this is worth doing
  # up front rather than after the first time a cockpit quietly drops an agent.
  printf '%s\n' "$names" | tail -n +2 | while read -r n; do
    [ -n "$n" ] || continue
    # -P -F to get the new pane's id back, so @dir lands on this split and not whichever
    # pane happened to be current — split-window makes the new pane active, but reading it
    # back by id is exact and does not assume that.
    pane=$(tmux split-window -t "$COCKPIT" -P -F '#{pane_id}' "$(view_cmd "$n")")
    tmux set-option -pt "$pane" @dir "$(cockpit_dir "$n")"
    tmux set-option -pt "$pane" @ag "$(cockpit_agent "$n")"
    tmux select-layout -t "$COCKPIT" tiled >/dev/null
  done
  tmux select-layout -t "$COCKPIT" "$layout" >/dev/null

  # The border label, free and always current: the inner client emits its session's title
  # (tmux.conf's set-titles-string — "claude · what it is working on") to its terminal,
  # which *is* this pane, so the cockpit reads it straight off #{pane_title}. No poll and
  # no bookkeeping, and it follows the agent's own title as the task changes. The global
  # format is no use here — every pane in a cockpit runs `tmux`, so #{pane_current_command}
  # would label all four "tmux". Set rather than inherited because the global exists for
  # other windows' reasons and apply_policy turns it off for agent sessions.
  #
  # Led with #{@dir}, the per-pane directory stamped above, so the border reads
  # "<dir> · claude · <task>": directory, then agent and task from the agent's own title.
  # @dir resolves at the pane scope, so each border shows its own agent's directory; the
  # ' · ' matches set-titles-string's separator so the three read as one string.
  #
  # The conditional drops the task half when it *is* the directory. Before an agent
  # publishes a task, set-titles-string falls back to "#{@agent} · #{b:pane_current_path}",
  # so pane_title is "claude · <dir>" and the naive form doubled the directory
  # ("<dir> · claude · <dir>"). Composing that fallback from the stamped @ag and @dir and
  # comparing pane_title to it catches exactly that state and shows "<dir> · claude"; any
  # real task fails the match and prints whole. Transient either way — it self-corrects the
  # moment the agent sets a title — but the doubling is avoided rather than blinked through.
  tmux set-option -w -t "$COCKPIT" pane-border-status top
  tmux set-option -w -t "$COCKPIT" pane-border-format \
    ' #{@dir} · #{?#{==:#{pane_title},#{@ag} · #{@dir}},#{@ag},#{pane_title}} '

  # Land on the one that most wants you. By pane id, which cannot be re-numbered out from
  # under us by the re-tiling above the way an index can.
  tmux select-pane -t "$home"

  # Already inside tmux (opened from an agent session, or from your own window): attach
  # would refuse to nest, and switch-client is what "go there" means to a client already here.
  [ -z "$TMUX" ] || exec tmux switch-client -t "=$COCKPIT"
  exec tmux attach-session -t "=$COCKPIT"
}

# ─── Where an agent may not be opened ────────────────────────────────────────
# An agent takes the directory you are standing in to be the project: it reads and edits
# from there, and launch() freezes it as the session root with -c "$PWD". Two directories
# are never the answer, and both are easy to arrive at without meaning to — every new
# terminal starts in $HOME, and a `cd "$somewhere"` with the variable unset lands in /.
# This box had an `aigent-/` session to show for it.
#
# Those two exactly, and nothing beneath them: every project lives under one or the other,
# so refusing what is *under* $HOME would refuse the whole machine.
#
# Measured with `pwd -P` rather than $PWD, which keeps whatever path you walked in by: a
# symlink pointing at $HOME is the same directory and reads as a different string, and
# that is precisely the route someone takes without noticing. The comparison resolves
# $HOME the same way so the two are judged alike.
#
# Only starting is refused, never reporting: `aigent status` answers for the whole box and
# is read-only, so it works from anywhere, and the fzf internals run from a picker that has
# already passed through here.
refuse_bad_cwd() {
  here=$(pwd -P)
  home=$(cd -P -- "$HOME" 2>/dev/null && pwd -P)

  what=
  [ "$here" = / ] && what=/
  [ -n "$home" ] && [ "$here" = "$home" ] && what="\$HOME"
  [ -n "$what" ] || return 0

  echo "aigent: refusing to open an agent in $what — cd into a project directory" >&2
  exit 1
}

# ─── Dispatch ────────────────────────────────────────────────────────────────
FORCE_NEW=
case $1 in
  new) FORCE_NEW=1 ;;
  status)
    status
    exit 0
    ;;
  # Above refuse_bad_cwd with status, and for the same reason: it opens no agent, so
  # where you are standing is not its business. You are most likely to want a cockpit
  # from wherever you happened to walk back to.
  cockpit)
    cockpit "$2"
    exit 0
    ;;
  --print-menu)
    print_menu
    exit 0
    ;;
  --peek)
    peek "$2"
    exit 0
    ;;
  --kill)
    kill_session "$2"
    exit 0
    ;;
  --toggle-yolo)
    toggle_yolo "$2"
    exit 0
    ;;
  '') ;;
  *)
    echo "aigent: unknown argument '$1'" >&2
    exit 1
    ;;
esac

refuse_bad_cwd

# Two per-invocation temp files, exported so the fzf-spawned --toggle-yolo / --print-menu /
# --kill subprocesses all share them. Both are removed the moment fzf returns and on
# Esc/interrupt via the trap, since the exec paths below never run to an EXIT trap of their own.
#
# AIGENT_YOLO_STATE — which agent (if any) you armed for YOLO with Tab. The chosen row's verb
#                     already carries the mode by the time fzf returns, so nothing reads it after.
# AIGENT_MENU_CACHE — the running-sessions block, classified once here rather than on every
#                     reload. print_menu is re-run for each Tab and ctrl-x; live_sessions() sleeps
#                     AGENT_SETTLE to sample screens twice, so recomputing it per keystroke is
#                     what delayed the Tab relabel. The snapshot does not change over the picker's
#                     life (fzf never refreshes it on its own), so caching loses no freshness.
AIGENT_YOLO_STATE="${TMPDIR:-/tmp}/aigent-yolo.$$"
AIGENT_MENU_CACHE="${TMPDIR:-/tmp}/aigent-menu.$$"
export AIGENT_YOLO_STATE AIGENT_MENU_CACHE
rm -f "$AIGENT_YOLO_STATE"
trap 'rm -f "$AIGENT_YOLO_STATE" "$AIGENT_MENU_CACHE"' EXIT INT TERM

# Classify the running sessions once, up front — the only place that pays classify's settle
# sleep on the picker's happy path. Empty (not absent) for `aigent new` or no tmux: print_menu
# reads this file, not FORCE_NEW, so the new-mode intent survives into the reload subprocesses,
# where $1 is --print-menu and FORCE_NEW is unset.
if [ -n "$USE_TMUX" ] && [ -z "$FORCE_NEW" ]; then
  live_sessions >"$AIGENT_MENU_CACHE"
else
  : >"$AIGENT_MENU_CACHE"
fi

MENU=$(print_menu) || exit 1

# --height=~80%: hug the content, capped at 80%, so three sessions don't open a
# full-screen box. --wrap because a task is a sentence and a narrow pane (Zed's terminal,
# nvim's right panel) can run past the edge — wrapping costs a row and shows all of it,
# where truncating would hide the field that tells two sessions of one project apart.
#
# tab arms the highlighted row for YOLO (toggle_yolo) and reloads so print_menu can relabel
# it; the reload keeps the cursor on the row, so Tab-then-Enter lands on what you armed.
set -- --prompt='Agent: ' --reverse --no-info --ansi --wrap \
  --delimiter='\t' --with-nth='3..' --height=~80% \
  --bind="tab:execute-silent($0 --toggle-yolo {2})+reload($0 --print-menu)"
if printf '%s\n' "$MENU" | grep -q '^attach'; then
  set -- "$@" --header='enter: start/attach   tab: YOLO   ctrl-x: kill' \
    --bind="ctrl-x:execute-silent($0 --kill {2})+reload($0 --print-menu)"
else
  set -- "$@" --header='enter: start   tab: YOLO'
fi

choice=$(printf '%s\n' "$MENU" | fzf "$@") || exit 0
rm -f "$AIGENT_YOLO_STATE" "$AIGENT_MENU_CACHE"
trap - EXIT INT TERM

# Field 2 is the target either way — a session name to attach to, or an agent to start.
# cut splits on TAB by default, the delimiter the menu is built with.
target=$(printf '%s' "$choice" | cut -f2)

case $choice in
  attach*)
    apply_policy "$target"
    exec tmux attach-session -t "=$target"
    ;;
  yolo*) launch "$target" yolo ;;
  *) launch "$target" ;;
esac
