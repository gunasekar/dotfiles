// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  // ── Window & Application ──────────────────────────────────────────────
  "proxy": "",
  "diff_view_style": "split",
  "cli_default_open_behavior": "new_window",
  "default_open_behavior": "new_window",

  // ── Theme & Fonts ─────────────────────────────────────────────────────
  "icon_theme": "Zed (Default)",
  "theme": "One Dark",
  "theme_overrides": {
    "One Dark": {
      "border": "#333333FF",
      "elevated_surface.background": "#000000FF",
      "surface.background": "#000000FF",
      "background": "#000000FF",
      "status_bar.background": "#000000FF",
      "title_bar.background": "#000000FF",
      "title_bar.inactive_background": "#2E343EFF",
      "toolbar.background": "#000000FF",
      "tab_bar.background": "#000000FF",
      "tab.inactive_background": "#000000FF",
      "tab.active_background": "#000000FF",
      "panel.background": "#000000FF",
      "editor.background": "#000000FF",
      "editor.gutter.background": "#000000FF",
      "editor.subheader.background": "#000000FF",
      "editor.highlighted_line.background": "#000000FF",
      "terminal.background": "#000000FF",
      "element.background": "#0a0a0aFF",
      "ghost_element.background": "#00000000",
      "drop_target.background": "#1a1a1aFF",
      "editor.active_line.background": "#111111FF",
      "search.match_background": "#3a3a00FF",
      "border.variant": "#222222FF",
      "panel.focused_border": "#4a4a4aFF",
      "hidden": "#777777FF",
      "hidden.background": "#00000000",
      "hidden.border": "#00000000",
      "ignored": "#666666FF",
      "ignored.background": "#00000000",
      "ignored.border": "#00000000",
    },
  },
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "agent_buffer_font_size": 13.0,
  "buffer_font_family": ".ZedMono",

  // ── Keymap ────────────────────────────────────────────────────────────
  "base_keymap": "VSCode",

  // ── Editor ──────────────────────────────────────────────────────────────
  "preferred_line_length": 120,
  "buffer_line_height": "comfortable",
  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_wrap_guides": true,
  "relative_line_numbers": "disabled",
  "cursor_blink": false,
  "vertical_scroll_margin": 5,
  "scroll_sensitivity": 1.5,
  "format_on_save": "on",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "vim_mode": false,

  // ── UI Chrome ───────────────────────────────────────────────────────────
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": true,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "close_position": "right",
  },
  "scrollbar": {
    "show": "auto",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "diagnostics": "all",
  },
  "gutter": {
    "line_numbers": true,
    "runnables": true,
    "folds": true,
  },

  // ── Panel Layout: Agentic ───────────────────────────────────────────────
  // Left:  agent panel + threads sidebar
  // Right: project, git, outline, collaboration
  // Bottom: terminal
  //
  // Classic layout: swap all "left" ↔ "right" dock values below.
  // Panel startup: project_panel.starts_open / git_panel.starts_open apply to
  // new workspaces; agent and terminal have no starts_open yet (zed #51542).
  // Per-workspace persisted dock state can still override on revisit.
  "agent": {
    "dock": "left",
    "sidebar_side": "left",
    "default_width": 750,
    "flexible": false,
    "button": false,
    "enabled": true,
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
    },
    "tool_permissions": {
      "default": "allow",
    },
    "play_sound_when_agent_done": "always",
    "expand_terminal_card": false,
    "expand_edit_card": false,
    // Reuse the same fzf agent picker as the nvim right-panel terminal.
    "terminal_init_command": "~/.config/nvim/scripts/agent-picker.sh",
  },
  "project_panel": {
    "dock": "right",
    "starts_open": true,
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true,
  },
  "git_panel": {
    "dock": "right",
    "starts_open": false,
    "sort_by_path": true,
    "tree_view": false,
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "terminal": {
    "dock": "bottom",
    "font_size": 12.0,
    "copy_on_select": true,
    "env": {
      "EDITOR": "zed --wait",
    },
  },

  // ── Git ─────────────────────────────────────────────────────────────────
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500,
    },
  },

  // ── AI ──────────────────────────────────────────────────────────────────
  "edit_predictions": {
    "provider": "zed",
    "ollama": {
      "model": "qwen2.5-coder:7b",
    },
  },

  // ── Telemetry ───────────────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },

  // ── LSP ─────────────────────────────────────────────────────────────────
  "lsp": {
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
        "analyses": {
          "nilness": true,
          "unusedparams": true,
          "unusedwrite": true,
          "useany": true,
        },
        "staticcheck": true,
        "usePlaceholders": true,
        "completeFunctionCalls": true,
        "vulncheck": "Imports",
      },
    },
  },

  // ── Languages ───────────────────────────────────────────────────────────
  "languages": {
    "Go": {
      "hard_tabs": true,
      "tab_size": 4,
      "formatter": "language_server",
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true,
      },
    },
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
        },
      },
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "JSON": {
      "formatter": "language_server",
    },
    "Markdown": {
      "soft_wrap": "editor_width",
    },
    "Shell Script": {
      "tab_size": 2,
      "hard_tabs": false,
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["--filename", "{buffer_path}", "-i", "2", "-ci"],
        },
      },
    },
  },
}
