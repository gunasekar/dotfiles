# Ghostty Configuration
# Claude Code + Neovim Integration Setup
# Based on: https://danielmiessler.com/blog/replacing-cursor-with-neovim-claude-code

# =============================================================================
# FONT & THEME
# =============================================================================
font-family = "Hack Nerd Font Mono"
# List all themes: ghostty +list-themes
theme = Tomorrow Night Bright

# =============================================================================
# WINDOW SETTINGS
# =============================================================================
window-padding-x = 8
window-padding-y = 8
window-theme = dark
macos-titlebar-style = tabs
macos-option-as-alt = true
maximize = true

# New tabs/splits/windows open in home directory instead of inheriting cwd.
window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = false
working-directory = home

# =============================================================================
# SPLITS & PANES - Claude Code Workflow Keybindings
# =============================================================================
split-divider-color = #555555
# Defaults use cmd+d (split right) and cmd+w (close); only overrides listed.

# Split down on cmd+shift+t (default: cmd+shift+d)
keybind = cmd+shift+t=new_split:down

# Vim-style pane navigation. performable: lets keys reach Neovim when no
# Ghostty split exists in that direction (required for Claude+Neovim workflow).
keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right

# Resize splits (default: cmd+ctrl+arrows)
keybind = cmd+ctrl+h=resize_split:left,10
keybind = cmd+ctrl+j=resize_split:down,10
keybind = cmd+ctrl+k=resize_split:up,10
keybind = cmd+ctrl+l=resize_split:right,10

# Toggle split zoom (overrides default redo on cmd+shift+z)
keybind = cmd+shift+z=toggle_split_zoom

# Equalize splits (default: cmd+ctrl+=)
keybind = cmd+shift+e=equalize_splits

# =============================================================================
# GENERAL SETTINGS
# =============================================================================
mouse-hide-while-typing = true
copy-on-select = false

# Smaller scrollback than default (10MB)
scrollback-limit = 10000

# Enable sudo/ssh shell integration (default disables sudo, ssh-env, ssh-terminfo)
shell-integration-features = cursor,sudo,title,ssh-env,ssh-terminfo

auto-update = check
auto-update-channel = stable

# Shift+Enter sends escape then return (useful for some REPLs)
keybind = shift+enter=text:\x1b\r
