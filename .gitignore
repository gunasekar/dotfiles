### macOS ###
# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon


# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

### macOS Patch ###
# iCloud generated files
*.icloud

# End of https://www.toptal.com/developers/gitignore/api/macos

### Custom Security Exclusions ###
# Never commit AWS credentials
aws/.aws/credentials

# Never commit SSH private keys
ssh/.ssh/id_*
ssh/.ssh/*_rsa
ssh/.ssh/*_ed25519
!ssh/.ssh/*.pub

# Never commit GPG private keys
gnupg/.gnupg/private-keys-v1.d/
gnupg/.gnupg/openpgp-revocs.d/
gnupg/.gnupg/pubring.kbx~

# Never commit password store
.password-store/

# Never commit work secrets file
sources/work/secrets.sh

### Temporary Files ###
*.tmp
*.bak
*.swp
*.swo
*~

### Logs ###
*.log

### IDEs and Editors ###
.idea/
.vscode/

### Environment Files ###
.env
.env.*
!.env.example
.envrc

### Security and Credentials ###
*.secret
*.key
*.pem
*.crt
*.p12
*.pfx
credentials.json
service-account.json
*-credentials.json

